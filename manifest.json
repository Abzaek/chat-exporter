{
  "manifest_version": 3,
  "name": "ChatGPT Exporter",
  "version": "1.0",
  "description": "Export ChatGPT conversations to Markdown.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Export Chat",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "host_permissions": [
    "https://chatgpt.com/*"
  ]
}